# ancroo-stack — Environment Configuration Example
#
# ⚠️  DO NOT COPY THIS FILE!
# This is a REFERENCE showing what variables install.sh and module.sh create.
# The actual .env file is auto-generated by install.sh and managed by module.sh.
#
# Purpose: Documentation of available configuration variables
# Location: .env (auto-generated, not in Git)

# ============================================================
# SYSTEM CONFIGURATION (set by install.sh)
# ============================================================

# Timezone (e.g., Europe/Berlin, America/New_York, Asia/Tokyo)
TZ="Europe/Berlin"

# GPU Mode: cpu | nvidia | rocm
GPU_MODE="cpu"

# Installation Mode: base | ssl
INSTALL_MODE="base"

# Docker Compose Files (managed by module.sh)
# Example values shown below - actual values depend on enabled modules
COMPOSE_FILE="docker-compose.yml:docker-compose.ports.yml"

# Enabled Modules (space-separated, managed by module.sh)
# Example: After enabling n8n and ssl
# ENABLED_MODULES="ssl n8n"
ENABLED_MODULES=""

# ============================================================
# DATABASE — PostgreSQL (auto-generated by install.sh)
# ============================================================

POSTGRES_USER="ancroo"
POSTGRES_PASSWORD="<auto-generated-32-char-random-string>"
POSTGRES_DB="ancroo"
DATABASE_URL="postgresql://ancroo:<password>@postgres:5432/ancroo"

# ============================================================
# OPEN WEBUI (auto-generated by install.sh)
# ============================================================

# Secret key for session management (base64, 48 bytes)
WEBUI_SECRET_KEY="<auto-generated-base64-string>"

# ============================================================
# HOMEPAGE DASHBOARD (auto-detected by install.sh)
# ============================================================

# User/Group IDs for file permissions
PUID="1000"
DOCKER_GID="999"

# Host IP for access URLs (auto-detected from hostname -I)
HOST_IP="192.168.1.100"

# ============================================================
# OPTIONAL MODULE VARIABLES
# The following variables are added by module.sh when modules are enabled.
# Listed here for reference only.
# ============================================================

# --- n8n (Workflow Automation) ---
# Added by: ./module.sh enable n8n
# N8N_PORT="5678"
# N8N_DOMAIN="n8n.example.com"  # Only in SSL mode
# N8N_DB="ancroo_n8n"
# N8N_ENCRYPTION_KEY="<auto-generated-hex-16>"
# ANCROO_N8N_API_KEY="<auto-provisioned-jwt>"  # Created by n8n post-enable.sh

# --- BookStack (Wiki / Knowledge Base) ---
# Added by: ./module.sh enable bookstack
# BOOKSTACK_PORT="8875"
# BOOKSTACK_DOMAIN="bookstack.example.com"  # Only in SSL mode
# BOOKSTACK_DB="ancroo_bookstack"
# BOOKSTACK_APP_KEY="<auto-generated-base64>"
# BOOKSTACK_DB_PASSWORD="<auto-generated-hex-64>"
# BOOKSTACK_DB_ROOT_PASSWORD="<auto-generated-hex-64>"

# --- SSL (Traefik + Let's Encrypt) ---
# Added by: ./module.sh enable ssl (runs setup.sh interactively)
# BASE_DOMAIN="example.com"
# TRAEFIK_DOMAIN="traefik.example.com"
# HOMEPAGE_DOMAIN="example.com"
# OPENWEBUI_DOMAIN="webui.example.com"
# OLLAMA_DOMAIN="ollama.example.com"
# DNS_PROVIDER="dns_inwx"  # Options: dns_inwx | dns_cf | dns_aws
# ACME_SERVER="letsencrypt_test"  # Options: letsencrypt_test (staging) | letsencrypt (production)
# ACME_EMAIL="admin@example.com"
#
# DNS Provider Credentials (one of the following sets):
# INWX:
# INWX_USERNAME="your-username"
# INWX_PASSWORD="your-password"
# INWX_SHARED_SECRET=""  # Optional for INWX 2FA
#
# Cloudflare:
# CF_EMAIL="your-email"
# CF_KEY="your-api-key"
#
# AWS Route53:
# AWS_ACCESS_KEY_ID="your-key"
# AWS_SECRET_ACCESS_KEY="your-secret"

# --- SSO (Keycloak) ---
# Added by: ./module.sh enable sso (runs setup.sh interactively)
# KEYCLOAK_DOMAIN="auth.example.com"
# KEYCLOAK_DB="ancroo_keycloak"
# KEYCLOAK_ADMIN="admin"
# KEYCLOAK_ADMIN_PASSWORD="<auto-generated-base64-24>"
# KEYCLOAK_REALM="ancroo"
# OAUTH2_PROXY_CLIENT_ID="ancroo-proxy"
# OAUTH2_PROXY_CLIENT_SECRET="<generated-by-keycloak-setup>"
# OAUTH2_PROXY_COOKIE_SECRET="<auto-generated-32-byte>"
#
# OAuth2 Credentials (generated by sso/post-enable.sh):
# OAUTH_CLIENT_ID="open-webui"
# OAUTH_CLIENT_SECRET="<generated-by-keycloak-api>"
# OAUTH_PROVIDER_NAME="Keycloak"

# --- Adminer (Database UI) ---
# Added by: ./module.sh enable adminer
# ADMINER_PORT="8081"
# ADMINER_DOMAIN="adminer.example.com"  # Only in SSL mode

# --- Speaches (Speech-to-Text) ---
# Added by: ./module.sh enable speaches
# SPEACHES_PORT="8100"
# SPEACHES_DOMAIN="speaches.example.com"  # Only in SSL mode
# SPEACHES_MODEL_SIZE="large-v3"

# --- Whisper ROCm (AMD GPU) ---
# Added by: ./module.sh enable whisper-rocm
# WHISPER_ROCM_PORT="8002"
# WHISPER_ROCM_DOMAIN="whisper.example.com"  # Only in SSL mode
# WHISPER_ROCM_MODEL="large-v3"

# --- Service Tools (Automation HTTP API) ---
# Added by: ./module.sh enable service-tools
# SERVICE_TOOLS_PORT="8500"
# SERVICE_TOOLS_DOMAIN="service-tools.example.com"  # Only in SSL mode

# --- Valkey (In-Memory Cache) ---
# Added automatically when sso is enabled (or as manual dependency)
# No configuration variables required

# ============================================================
# NOTES
# ============================================================
#
# 1. DO NOT create .env manually - run install.sh instead
# 2. DO NOT commit .env to Git (already in .gitignore)
# 3. Passwords are auto-generated for security
# 4. Module-specific variables are added by module.sh enable <module>
# 5. SSL/SSO modules run interactive setup.sh scripts
# 6. Use module.sh info <module> to see module-specific variables
# 7. Backup .env securely - it contains all credentials
#
# ============================================================
# EXAMPLE: Typical .env after enabling ssl + sso + n8n
# ============================================================
#
# TZ="Europe/Berlin"
# GPU_MODE="nvidia"
# INSTALL_MODE="ssl"
# COMPOSE_FILE="docker-compose.yml:modules/gpu-nvidia/compose.yml:modules/ssl/compose.yml:modules/valkey/compose.yml:modules/sso/compose.yml:modules/n8n/compose.yml"
# ENABLED_MODULES="gpu-nvidia ssl valkey sso n8n"
# BASE_DOMAIN="ai.example.com"
# KEYCLOAK_DOMAIN="auth.ai.example.com"
# N8N_DOMAIN="n8n.ai.example.com"
# ...
