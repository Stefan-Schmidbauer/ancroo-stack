# --- Keycloak ---
KEYCLOAK_DOMAIN=auth.localhost
KEYCLOAK_DB=ancroo_keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-generate-in-setup
KEYCLOAK_REALM=ancroo
# --- oauth2-proxy ---
OAUTH2_PROXY_CLIENT_ID=ancroo-proxy
OAUTH2_PROXY_CLIENT_SECRET=changeme
OAUTH2_PROXY_COOKIE_SECRET=changeme-generate-in-setup
# --- Open WebUI OAuth (wird von post-enable.sh gesetzt) ---
ENABLE_OAUTH_SIGNUP=true
ENABLE_LOGIN_FORM=true
OAUTH_PROVIDER_NAME=Keycloak
OAUTH_CLIENT_ID=open-webui
OAUTH_CLIENT_SECRET=changeme
OAUTH_SCOPES=openid email profile
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
OPENID_PROVIDER_URL=http://keycloak:8080/realms/ancroo/.well-known/openid-configuration
OAUTH_AUTHORIZATION_URL=https://auth.localhost/realms/ancroo/protocol/openid-connect/auth
OAUTH_TOKEN_URL=http://keycloak:8080/realms/ancroo/protocol/openid-connect/token
OAUTH_USERINFO_URL=http://keycloak:8080/realms/ancroo/protocol/openid-connect/userinfo
