WHISPER_ROCM_PORT=8002
WHISPER_ROCM_DOMAIN=whisper-rocm.localhost
WHISPER_ROCM_MODEL=openai/whisper-large-v3-turbo
# AMD GPU architecture override for ROCm compatibility
# Only needed if your GPU is not natively supported by the ROCm version in use.
# Modern ROCm/Ollama builds support gfx1151 (RDNA 4) natively — leave empty.
# Check your GPU: rocminfo | grep gfx
#HSA_OVERRIDE_GFX_VERSION=11.0.0
