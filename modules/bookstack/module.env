# BookStack Default Environment Variables
BOOKSTACK_PORT=8875
BOOKSTACK_DOMAIN=bookstack.localhost
BOOKSTACK_APP_URL=http://localhost:8875
BOOKSTACK_APP_KEY=CHANGE_ME_app_key
BOOKSTACK_DB_HOST=bookstack-db
BOOKSTACK_DB_PORT=3306
BOOKSTACK_DB_DATABASE=bookstack
BOOKSTACK_DB_USER=bookstack
BOOKSTACK_DB_PASSWORD=CHANGE_ME_db_password
BOOKSTACK_DB_ROOT_PASSWORD=CHANGE_ME_db_root_password
BOOKSTACK_ADMIN_EMAIL=admin@admin.com
BOOKSTACK_ADMIN_PASSWORD=CHANGE_ME_admin_password
