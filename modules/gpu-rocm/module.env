# AMD GPU acceleration for Ollama
# Check your GPU architecture: rocminfo | grep gfx

# --- Mode 1: ROCm/HIP (default) ---
# Works with: gfx1030 (RDNA 2), gfx1100/1101/1102 (RDNA 3)
# Set HSA_OVERRIDE_GFX_VERSION if your GPU needs an architecture override.
# Empty default suppresses Docker Compose warning; entrypoint unsets if empty.
HSA_OVERRIDE_GFX_VERSION=
#HSA_OVERRIDE_GFX_VERSION=11.0.0

# --- Mode 2: Vulkan (recommended for gfx1151 / RDNA 3.5 / Strix Halo) ---
# The official ROCm image lacks working HIP kernels for gfx1151.
# Vulkan bypasses HIP entirely and is faster on gfx1151 for prompt processing.
# Uncomment all three lines below to enable Vulkan mode:
#OLLAMA_IMAGE_TAG=latest
#OLLAMA_VULKAN=1
#HIP_VISIBLE_DEVICES=-1
